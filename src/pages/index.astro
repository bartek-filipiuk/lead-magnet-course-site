---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllLessons } from "../lib/course";

const lessons = getAllLessons();

const discordUrl = "https://discord.gg/mSSqkQWe4D";
---

<BaseLayout
  title="Kurs: Od pomysłu do deploy"
  description="Spis lekcji kursu i szybki dostęp do materiałów."
>
  <section class="hero">
    <h1>Od pomysłu do deploy w weekend</h1>
    <p class="muted">
      Praktyczny kurs: od jednego pomysłu do działającej aplikacji pod własną
      domeną.
    </p>
    <p>
      Lekcja 1 dostępna od razu. Reszta kursu + prompty po zapisie na newsletter.
    </p>
  </section>

  <section class="video-section">
    <div class="video-embed-placeholder">
      <div class="video-play-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3" /></svg>
      </div>
      <p style="margin: 0;">Film wkrótce</p>
    </div>
  </section>

  <section>
    <h2>Szybki start</h2>
    <div class="grid quick-start-grid">
      <a href="/prompt-startowy/" class="lesson-card quick-start-card">
        <div class="quick-start-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" /></svg>
        </div>
        <div class="quick-start-body">
          <h3>Prompt startowy</h3>
          <p class="muted">Gotowy zestaw promptów, które prowadzą AI przez cały proces budowy.</p>
        </div>
      </a>
      <a href={discordUrl} target="_blank" rel="noreferrer" class="lesson-card quick-start-card">
        <div class="quick-start-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
        </div>
        <div class="quick-start-body">
          <h3>Discord (główne wsparcie)</h3>
          <p class="muted">Wrzucaj pytania, błędy i screeny.</p>
        </div>
      </a>
    </div>
  </section>

  <section>
    <h2>Spis lekcji</h2>
    <div class="grid">
      {
        lessons.map((lesson) => (
          <a href={`/lekcja/${lesson.slug}/`} class="lesson-card lesson-card--numbered">
            <div class="lesson-number">{lesson.order}</div>
            <div class="lesson-card-body">
              <h3>{lesson.title}</h3>
              <p class="muted">{lesson.description}</p>
              <div class="lesson-meta">
                <span class="badge badge--duration">{lesson.duration}</span>
                {lesson.isBonus
                  ? <span class="badge badge--bonus">Bonus</span>
                  : <span class="badge badge--core">Rdzeń</span>}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
