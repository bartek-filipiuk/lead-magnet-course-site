---
export const prerender = false;

import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import EmailGate from "../components/EmailGate.astro";

const authenticated = Astro.locals.authenticated;

const courseUrl = "https://vibe.devince.dev";
const discordUrl = "https://discord.gg/mSSqkQWe4D";
const youtubeUrl = "https://www.youtube.com/@bartfilipiuk/videos";
const bootstrapPromptUrl = `${courseUrl}/prompts/BOOTSTRAP_PROMPT.md`;

let files: { id: string; filename: string; label: string; description: string; content: string }[] = [];

if (authenticated) {
  const promptsDir = path.resolve(process.cwd(), "content/prompts");
  files = [
    {
      id: "bootstrap-prompt",
      filename: "BOOTSTRAP_PROMPT.md",
      label: "Bootstrap Prompt",
      description: "Jednolinijkowa instrukcja startowa: agent po wklejeniu linku sam tworzy wymagane pliki w katalogu wskazanym przez użytkownika.",
      content: fs.readFileSync(path.join(promptsDir, "BOOTSTRAP_PROMPT.md"), "utf-8").trim(),
    },
    {
      id: "agent-init",
      filename: "AGENT_INIT_PROMPT.md",
      label: "Prompt startowy",
      description: "Prowadzi agenta przez 5 faz: od pomysłu przez TDD do deployu. Zawiera checkpointy GATE, które blokują przejście do następnej fazy, jeśli brakuje artefaktów.",
      content: fs.readFileSync(path.join(promptsDir, "AGENT_INIT_PROMPT.md"), "utf-8").trim(),
    },
    {
      id: "artifact-checklist",
      filename: "ARTIFACT_CHECKLIST.md",
      label: "Artifact Checklist",
      description: "Referencyjny dokument z pełną listą wymaganych plików dla każdej fazy i kryteriami akceptacji. Agent odwołuje się do niego przy każdym GATE.",
      content: fs.readFileSync(path.join(promptsDir, "ARTIFACT_CHECKLIST.md"), "utf-8").trim(),
    },
    {
      id: "verification-prompt",
      filename: "VERIFICATION_PROMPT.md",
      label: "Verification Prompt",
      description: "Niezależny prompt audytowy. Wklej go do dowolnego agenta w dowolnym momencie, żeby sprawdzić stan projektu i dostać raport, czego brakuje.",
      content: fs.readFileSync(path.join(promptsDir, "VERIFICATION_PROMPT.md"), "utf-8").trim(),
    },
    {
      id: "handoff-check",
      filename: "PROMPT_HANDOFF_CHECK.md",
      label: "Handoff Check",
      description: "Szybki check struktury HANDOFF_STAGES_PLAN.md. Weryfikuje czy każdy stage ma wymagane sekcje (Security, Docs, Stage Completion, User Stories) i czy Coverage Check pokrywa wszystkie User Stories z PRD.",
      content: fs.readFileSync(path.join(promptsDir, "PROMPT_HANDOFF_CHECK.md"), "utf-8").trim(),
    },
  ];
}
---

<BaseLayout
  title="Prompt startowy: AGENT_INIT_PROMPT"
  description="4 pliki markdown, które prowadzą agenta AI przez cały proces budowania apki — od pomysłu do deployu."
>
  <section class="hero prompt-hero">
    <h1>Pliki startowe (to jest sedno całego flow)</h1>
    <p class="muted">
      4 pliki markdown, które prowadzą agenta AI przez cały proces: od pomysłu
      i PRD, przez plan i kodowanie z checkpointami GATE, aż do deployu.
    </p>
    <div class="inline-links">
      <a href={courseUrl} target="_blank" rel="noreferrer">Otwórz kurs</a>
      <a href={discordUrl} target="_blank" rel="noreferrer">Dołącz na Discord</a>
      <a href={youtubeUrl} target="_blank" rel="noreferrer">Zobacz demo na YouTube</a>
    </div>
  </section>

  {authenticated ? (
    <section class="info-card">
      <h2>Jak to odpalić</h2>
      <ol class="setup-steps">
        <li>
          <strong>Stwórz pusty katalog</strong> na swój projekt (np. <code>my-app/</code>).
        </li>
        <li>
          <strong>Wklej do agenta jedną linijkę</strong> (link do instrukcji bootstrap):
          <pre class="prompt-pre prompt-pre--short"><code>{`Przeczytaj instrukcję z ${bootstrapPromptUrl} i wykonaj ją krok po kroku.`}</code></pre>
          <div class="download-cta">
            <a class="download-btn" href="/prompts/BOOTSTRAP_PROMPT.md" target="_blank" rel="noreferrer">Otwórz BOOTSTRAP_PROMPT.md</a>
          </div>
        </li>
        <li>
          <strong>Wskaż agentowi katalog docelowy</strong>. Agent utworzy tam pliki:
          <div class="file-list">
            <code>AGENT_INIT_PROMPT.md</code> — główny prompt
            <code>ARTIFACT_CHECKLIST.md</code> — lista artefaktów (agent czyta przy GATE)
            <code>VERIFICATION_PROMPT.md</code> — niezależny audyt (opcjonalnie, w dowolnym momencie)
            <code>PROMPT_HANDOFF_CHECK.md</code> — check struktury HANDOFF (agent uruchamia w GATE 2)
          </div>
        </li>
        <li>
          <strong>Gdy pliki będą gotowe</strong>, otwórz agenta AI (Claude Code, Cursor, Windsurf) w tym katalogu i wklej:
          <pre class="prompt-pre prompt-pre--short"><code>Przeczytaj AGENT_INIT_PROMPT.md i ARTIFACT_CHECKLIST.md. Zacznij.</code></pre>
        </li>
        <li>
          <strong>Podaj pomysł</strong> jednym zdaniem i pozwól agentowi prowadzić Cię przez fazy.
        </li>
      </ol>
    </section>

    <section class="prompt-grid">
      <article class="info-card">
        <h2>Co dobrze przygotować przed startem</h2>
        <ul>
          <li>konto na GitHubie (łatwiej zapisywać progres),</li>
          <li>90 minut spokojnego czasu na pierwszy przebieg,</li>
          <li>
            opcjonalnie: VPS, jeśli chcesz od razu wystawić apkę publicznie po
            ukończeniu.
          </li>
        </ul>
      </article>

      <article class="info-card">
        <h2>Gdzie ludzie najczęściej się wykładają</h2>
        <ul>
          <li>proszą agenta o &bdquo;zrób wszystko naraz&rdquo; zamiast task po tasku,</li>
          <li>pomijają testy i wracają do bugów po kilku dniach,</li>
          <li>nie aktualizują dokumentacji po stage'u,</li>
          <li>nie robią commitów po domkniętym kroku.</li>
        </ul>
        <p class="muted">
          Jeśli utkniesz: wrzuć kontekst i błąd na Discorda.
        </p>
      </article>
    </section>
  ) : null}

  {files.map((file) => (
    <section class="info-card prompt-file-section" id={file.id}>
      <div class="prompt-file-header">
        <div>
          <h2>{file.filename}</h2>
          <p class="muted">{file.description}</p>
        </div>
        <button
          class="copy-btn"
          data-target={file.id}
          aria-label={`Skopiuj ${file.filename}`}
        >
          <span class="copy-btn__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </span>
          <span class="copy-btn__label">Kopiuj</span>
        </button>
      </div>
      <pre class="prompt-pre" id={`content-${file.id}`}><code>{file.content}</code></pre>
    </section>
  ))}

  {!authenticated && <EmailGate />}
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const targetId = btn.dataset.target;
      const codeEl = document.querySelector(`#content-${targetId} code`);
      if (!codeEl) return;

      try {
        await navigator.clipboard.writeText(codeEl.textContent || "");
        const label = btn.querySelector(".copy-btn__label");
        if (label) {
          const prev = label.textContent;
          label.textContent = "Skopiowano!";
          btn.classList.add("copy-btn--success");
          setTimeout(() => {
            label.textContent = prev;
            btn.classList.remove("copy-btn--success");
          }, 2000);
        }
      } catch {
        const textarea = document.createElement("textarea");
        textarea.value = codeEl.textContent || "";
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);

        const label = btn.querySelector(".copy-btn__label");
        if (label) {
          const prev = label.textContent;
          label.textContent = "Skopiowano!";
          btn.classList.add("copy-btn--success");
          setTimeout(() => {
            label.textContent = prev;
            btn.classList.remove("copy-btn--success");
          }, 2000);
        }
      }
    });
  });
</script>

<style>
  .download-cta {
    margin-top: 0.6rem;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--accent);
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: background var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }

  .download-btn:hover {
    background: var(--accent);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .setup-steps li {
    margin-bottom: 0.8rem;
  }

  .file-list {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin: 0.5rem 0 0.2rem;
    padding-left: 0.2rem;
  }

  .file-list code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--code-bg);
    padding: 0.15em 0.4em;
    border-radius: 5px;
  }

  .prompt-pre--short {
    max-height: none;
    margin-top: 0.5rem;
  }

  .prompt-file-section {
    scroll-margin-top: 90px;
  }

  .prompt-file-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .prompt-file-header h2 {
    margin: 0 0 0.3rem;
    font-family: var(--font-mono);
    font-size: 1.15rem;
  }

  .prompt-file-header .muted {
    margin: 0 0 0.8rem;
    font-size: 0.92rem;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    color: var(--muted);
    font-family: inherit;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .copy-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-soft);
    transform: translateY(-1px);
  }

  .copy-btn--success {
    border-color: #16a34a;
    color: #16a34a;
    background: #f0fdf4;
  }

  .copy-btn__icon {
    display: flex;
    align-items: center;
  }
</style>
